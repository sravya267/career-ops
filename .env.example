# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.0-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.0-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-thinking-exp
# GEMINI_MODEL=gemini-2.0-flash

# ── Job Board API + BigQuery pipeline (job-board-api/) ──────────────────────
# Required for the Cloud Run service in job-board-api/.
# See job-board-api/.env.example for the full set of options.

# GCP project that owns the BigQuery dataset
# BQ_PROJECT=your-gcp-project-id

# BigQuery dataset / table names (defaults shown)
# BQ_DATASET=career_ops
# BQ_JOBS_TABLE=jobs
# BQ_SCORES_TABLE=scores

# Brief candidate description used by Gemini when scoring jobs.
# 3-5 sentences: experience, stack, target roles, location preference.
# CANDIDATE_PROFILE=Fullstack data and analytics professional with 14+ years of hands-on experience in data engineering, ML/AI, and advanced analytics. Deep expertise in Python, PySpark, SQL, GCP, Azure, and AWS; hands-on with LLMs, NLP, prompt engineering, and GenAI automation. Delivered $200K+ pipeline savings at a Fortune 500 (JLL) and currently building AI-powered applications using FastAPI and ML. Targeting mid-level to senior individual contributor roles in Data Engineering, ML Engineering, or Applied AI — not looking for management or team-lead positions. Open to remote or hybrid.

# Comma-separated title keywords — only fetch jobs matching at least one.
# TITLE_KEYWORDS=engineer,scientist,ai,ml,machine learning,data

# Max jobs to score per Cloud Run invocation (free tier: 50 is safe)
# MAX_JOBS_PER_RUN=50

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration
