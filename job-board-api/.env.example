# career-ops job-board-api — Environment Variables
# Copy to .env for local development: cp .env.example .env
#
# In Cloud Run, set these as environment variables in the service config
# or via Secret Manager.

# ── Gemini (required for scoring) ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ── BigQuery (required for storage) ──────────────────────────────────────────
BQ_PROJECT=your-gcp-project-id
# BQ_DATASET=career_ops
# BQ_JOBS_TABLE=jobs
# BQ_SCORES_TABLE=scores

# ── Candidate profile (used by Gemini for scoring) ───────────────────────────
# A brief description of the candidate (3-5 sentences).
# Example: "Senior AI Engineer with 6 years of experience in LLMs, Python, and
# distributed systems. Strong background in prompt engineering and fine-tuning.
# Targeting Staff/Principal IC roles at AI-first companies. Prefers remote."
CANDIDATE_PROFILE=Fullstack data and analytics professional with 14+ years of hands-on experience in data engineering, ML/AI, and advanced analytics. Deep expertise in Python, PySpark, SQL, GCP, Azure, and AWS; hands-on with LLMs, NLP, prompt engineering, and GenAI automation. Delivered $200K+ pipeline savings at a Fortune 500 (JLL) and currently building AI-powered applications independently using FastAPI and ML. Targeting mid-level to senior individual contributor roles in Data Engineering, ML Engineering, or Applied AI — not looking for management or team-lead positions. Open to remote or hybrid.

# ── Job filtering ─────────────────────────────────────────────────────────────
# Comma-separated keywords — only fetch jobs whose title contains at least one.
# TITLE_KEYWORDS=engineer,scientist,ai,ml,machine learning,data

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Max jobs to score per pipeline run (free-tier Gemini: ~50/run is safe)
# MAX_JOBS_PER_RUN=50

# Set to true to fetch full Greenhouse job descriptions (adds N extra HTTP calls)
# FETCH_DESCRIPTIONS=false

# ── Google Cloud auth (local dev only) ────────────────────────────────────────
# In Cloud Run, the service account is used automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
